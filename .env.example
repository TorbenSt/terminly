APP_NAME="Appointment Scheduler"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=appointment_scheduler
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@appointment-scheduler.test"
MAIL_FROM_NAME="${APP_NAME}"

# xAI / Grok API (GROK_API_KEY is used by grok-php/laravel; XAI_API_KEY is an alias)
# Collections: Management-Key für create/upload, API-Key für documents/search
XAI_API_KEY=
XAI_MANAGEMENT_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_COLLECTIONS_BASE_URL=https://management-api.x.ai/v1
GROK_PROSPECT_COLLECTION_PREFIX=appointment-prospect-feedback
GROK_COLLECTION_SEARCH_LIMIT=10
GROK_API_KEY="${XAI_API_KEY}"
GROK_DEFAULT_MODEL=grok-2-latest
GROK_DEFAULT_TEMPERATURE=0.3
GROK_API_TIMEOUT=120

# Stripe / Laravel Cashier (Testmode-Keys für lokale Entwicklung, Live-Keys in Produktion)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=de

# Google Places (Kundensuche)
GOOGLE_PLACES_API_KEY=
PROSPECT_MAX_RESULTS_CAP=100
PROSPECT_RETENTION_DAYS=365
PROSPECT_OUTREACH_RATE_LIMIT_PER_DAY=20

PROSPECT_DISPATCH_AFTER_RESPONSE=true

# Apify (Google Maps Scraper für Kundensuche)
# https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_PROSPECT_ACTOR_ID=compass/crawler-google-places
APIFY_POLL_MAX_ATTEMPTS=72
APIFY_POLL_INTERVAL_SECONDS=5

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

HORIZON_PREFIX=appointment_horizon:
